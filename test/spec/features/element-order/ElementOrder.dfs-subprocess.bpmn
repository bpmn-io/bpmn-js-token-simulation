<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_1" isExecutable="true">
    <bpmn:startEvent id="ROOT_START" name="Root Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="ROOT_START" targetRef="SUB_PROCESS" />
    <bpmn:subProcess id="SUB_PROCESS" name="Sub Process">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:startEvent id="SUB_START" name="Sub Start">
        <bpmn:outgoing>Flow_2</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:sequenceFlow id="Flow_2" sourceRef="SUB_START" targetRef="SUB_TASK" />
      <bpmn:task id="SUB_TASK" name="Sub Task">
        <bpmn:incoming>Flow_2</bpmn:incoming>
        <bpmn:outgoing>Flow_3</bpmn:outgoing>
      </bpmn:task>
      <bpmn:sequenceFlow id="Flow_3" sourceRef="SUB_TASK" targetRef="SUB_END" />
      <bpmn:endEvent id="SUB_END" name="Sub End">
        <bpmn:incoming>Flow_3</bpmn:incoming>
      </bpmn:endEvent>
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="SUB_PROCESS" targetRef="ROOT_END" />
    <bpmn:endEvent id="ROOT_END" name="Root End">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1">
      <bpmndi:BPMNShape id="ROOT_START_di" bpmnElement="ROOT_START">
        <dc:Bounds x="100" y="150" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SUB_PROCESS_di" bpmnElement="SUB_PROCESS" isExpanded="true">
        <dc:Bounds x="200" y="80" width="350" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SUB_START_di" bpmnElement="SUB_START">
        <dc:Bounds x="240" y="150" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SUB_TASK_di" bpmnElement="SUB_TASK">
        <dc:Bounds x="320" y="128" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="SUB_END_di" bpmnElement="SUB_END">
        <dc:Bounds x="470" y="150" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ROOT_END_di" bpmnElement="ROOT_END">
        <dc:Bounds x="620" y="150" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="136" y="168" />
        <di:waypoint x="200" y="168" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="276" y="168" />
        <di:waypoint x="320" y="168" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="420" y="168" />
        <di:waypoint x="470" y="168" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="550" y="168" />
        <di:waypoint x="620" y="168" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
